{
  "experiment_name": "switch_e15",
  "network_type": "resnet18",
  "dataset_id": "cifar100",
  "random_seed": 42,
  "training_policy": {
    "epochs": 50,
    "accuracy_threshold": null
  },
  "snapshot_policy": {
    "milestone_count": 10,
    "distribution_scheme": "uniform",
    "samples_per_class": 100
  },
  "transform_config": {
    "normalize_mean": [
      0.5071,
      0.4867,
      0.4408
    ],
    "normalize_std": [
      0.2675,
      0.2565,
      0.2761
    ],
    "augmentation_enabled": true,
    "random_crop_padding": 4,
    "horizontal_flip": true
  },
  "optimizer": {
    "type": "sgd",
    "learning_rate": 0.1,
    "weight_decay": 0.0005,
    "momentum": 0.9,
    "nesterov": true
  },
  "sae_policy": {
    "expansion_factor": 4,
    "k_sparse": 32,
    "n_steps": 5000,
    "shared_init_seed": 42,
    "null_permutations": 100
  },
  "curriculum_policy": {
    "enabled": true,
    "phases": [
      {
        "start_epoch": 1,
        "end_epoch": 15,
        "label_mode": "superclass",
        "learning_rate": 0.1
      },
      {
        "start_epoch": 16,
        "end_epoch": 50,
        "label_mode": "fine",
        "learning_rate": 0.01
      }
    ]
  },
  "noise_policy": null
}
